# Backend .env template
# Copy this file to .env and fill in your values
# NEVER commit this file to version control

TRANSCRIPT_ENCRYPTION_KEY=96fdecf67a48e82e2e42dbc4aa6806c7a09066ee84cdff8ac383e0796dbb24bb

# Blockchain configuration
# Options: localhost, sepolia, mainnet
ETHEREUM_NETWORK=localhost
CONTRACT_ADDRESS=

# Your wallet private key (needed for sepolia/mainnet)
# Include the "0x" prefix
PRIVATE_KEY=

# Sepolia RPC URL (optional - will use public RPC if not provided)
# SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Mainnet RPC URL (optional)
# MAINNET_RPC_URL=https://eth.llamarpc.com

# IPFS configuration
IPFS_HOST=127.0.0.1
IPFS_PORT=5001